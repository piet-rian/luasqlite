// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-outside-of-docker-compose
{
  "name": "lua-sqlite",
  "dockerComposeFile": "compose.yaml",
  "service": "devcontainer", // compose.yaml内のサービス名を指定
  // ${localWorkspaceFolderBasename} はローカル(WLS上)のプロジェクトルートのフォルダ名に置き換えられる
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  // Use this environment variable if you need to bind mount your local source code into a new container.
  "remoteEnv": {
    // "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}"
  },
  // 開発環境に追加する機能を指定
  "features": {
    // WLS2上のDockerデーモンを使用可能にする
    "ghcr.io/devcontainers/features/docker-outside-of-docker:latest": {
      "moby": "false", // trixieはmoby未対応@2026-02-11 // https://github.com/apache/superset/issues/37180#issuecomment-3759792394
      "enableNonRootDocker": "true" // 非rootユーザーでdockerコマンドを使用可能にする
    },
    // luaのインストール
    "ghcr.io/prulloac/devcontainer-features/lua:1": {
      "version": "5.4.8", // Luaのバージョンを指定 // モジュール側が5.5対応してない物が多いため
      "useApt": "false" // aptではなくソースコードからインストールする(lua.orgから最新の安定版を取得)
    },
    // sqliteのインストール
    "ghcr.io/rails/devcontainer/features/sqlite3": {
      // railsと書いてあるが、内容としてはapt経由でsqlite3をインストールするだけのものなのでluaプロジェクトでも利用可能
    }
  },
  "customizations": {
    "vscode": {
      // 必ず導入する拡張機能を指定
      "extensions": [
        "ms-azuretools.vscode-containers",
        "tomblind.local-lua-debugger-vscode",
        "alexcvzz.vscode-sqlite"
      ]
    }
  },
  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // "forwardPorts": [],
  // コンテナビルド後に一回だけ実行されるコマンドを指定
  // see. https://containers.dev/implementors/json_reference/#lifecycle-scripts
  // memo. ファイル名だけ渡すと実行権限不足で失敗するため、シェル経由で実行する
  "postCreateCommand": "/bin/sh .devcontainer/postCreateCommand.sh"
  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  // "remoteUser": "root"
}
