// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-outside-of-docker-compose
{
  "name": "lua-sqlite",
  "dockerComposeFile": "compose.yaml",
  "service": "devcontainer", // compose.yaml内のサービス名を指定
  "workspaceFolder": "/workspaces/",
  // Use this environment variable if you need to bind mount your local source code into a new container.
  "remoteEnv": {
    "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}"
  },
  // 開発環境に追加する機能を指定
  "features": {
    // WLS2上のDockerデーモンを使用可能にする
    "ghcr.io/devcontainers/features/docker-outside-of-docker:latest": {
      "enableNonRootDocker": "true" // 非rootユーザーでdockerコマンドを使用可能にする
    },
    "ghcr.io/prulloac/devcontainer-features/lua:1": {}
  },
  "customizations": {
    "vscode": {
      // 必ず導入する拡張機能を指定
      "extensions": [
        "ms-azuretools.vscode-containers"
      ]
    }
  }
  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // "forwardPorts": [],
  // Use 'postCreateCommand' to run commands after the container is created.
  // "postCreateCommand": "docker --version",
  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  // "remoteUser": "root"
}
